<?xml version="1.0" encoding="UTF-8"?>
<!--
    Alfresco Content Model for CMCourier staging dry-runs.

    Declares one type ``cmcourier:bacDoc`` that extends ``cm:content``
    and adds the metadata properties CMCourier's MetadataService
    typically emits during S3. Lets Alfresco accept upload requests
    where ``cmis:objectTypeId = D:cmcourier:bacDoc`` carrying these
    custom properties without rejecting them as undeclared.

    Deployment:
      Run ``bash scripts/staging/register-model.sh`` on the staging host
      after Alfresco is healthy. It zips this XML and POSTs it to
      ``/alfresco/service/api/cmm/upload``, then activates the model
      via the CMM v1 REST API. Idempotent.

      Do NOT copy this file into the Alfresco extension volume mount —
      in Alfresco 23.x Community that path is no longer scanned for
      Spring bootstrap, and worse, the classpath pre-scan reserves
      the namespace prefix from any model XML it finds there, blocking
      a subsequent CMM upload with HTTP 409.

    CMIS view of the type:
      The model name and the type both live under the ``cmcourier``
      namespace prefix. After activation CMIS clients see the type as
      ``D:cmcourier:bacDoc`` (the ``D:`` marks it as a ``cmis:document``
      subtype). Plain ``cmcourier:bacDoc`` works inside CMIS-SQL
      ``FROM`` clauses; everywhere else use the ``D:`` form.

    Why ``name="cmcourier:cmcourierBacModel"`` and not ``contentModel``:
      The CMM upload validator checks the part after the prefix for
      global uniqueness — ``contentModel`` collides with the built-in
      ``cm:contentModel`` and the upload is rejected with HTTP 409.

    Not faithful to production:
      This model is NOT a copy of the bank's IBM CM type definitions
      (those use the ``$t!-N_BAC_…v-1`` ID format Alfresco rejects on
      syntax). It's a single working stand-in so the end-to-end pipeline
      runs without per-property validation rejections.

    Add or rename properties to match the metadata fields your
    MapeoRVI_CM / MetadatosCM sample actually emits.
-->
<model name="cmcourier:cmcourierBacModel"
       xmlns="http://www.alfresco.org/model/dictionary/1.0">

    <description>Staging-only content model for CMCourier dry-runs.</description>
    <author>CMCourier</author>
    <version>1.0</version>

    <imports>
        <import uri="http://www.alfresco.org/model/dictionary/1.0" prefix="d"/>
        <import uri="http://www.alfresco.org/model/content/1.0" prefix="cm"/>
    </imports>

    <namespaces>
        <namespace uri="http://cmcourier.example/model/content/1.0" prefix="cmcourier"/>
    </namespaces>

    <types>
        <type name="cmcourier:bacDoc">
            <title>CMCourier BAC document (staging)</title>
            <parent>cm:content</parent>
            <properties>
                <!-- Common metadata fields. Extend / rename to match
                     the bank's required_metadata_fields set you load
                     in MetadatosCM.csv. All declared as d:text so we
                     do not impose validation we cannot mirror in
                     prod's IBM CM. -->
                <property name="cmcourier:BAC_CIF">
                    <title>BAC CIF</title>
                    <type>d:text</type>
                    <mandatory>false</mandatory>
                </property>
                <property name="cmcourier:Nombre_Cliente">
                    <title>Nombre del cliente</title>
                    <type>d:text</type>
                    <mandatory>false</mandatory>
                </property>
                <property name="cmcourier:Short_Name">
                    <title>Short name</title>
                    <type>d:text</type>
                    <mandatory>false</mandatory>
                </property>
                <property name="cmcourier:Fvenc_Inicio">
                    <title>Fecha de vencimiento (inicio)</title>
                    <type>d:text</type>
                    <mandatory>false</mandatory>
                </property>
                <property name="cmcourier:Fvenc_Fin">
                    <title>Fecha de vencimiento (fin)</title>
                    <type>d:text</type>
                    <mandatory>false</mandatory>
                </property>
                <property name="cmcourier:NUM_CUENTA_TARJETA">
                    <title>Número de cuenta / tarjeta</title>
                    <type>d:text</type>
                    <mandatory>false</mandatory>
                </property>
            </properties>
        </type>
    </types>
</model>
