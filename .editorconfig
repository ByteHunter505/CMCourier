# EditorConfig — https://editorconfig.org
# CMCourier project conventions: 4-space indent, LF line endings, UTF-8.

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
# Markdown uses two trailing spaces as a hard line break.
trim_trailing_whitespace = false

[*.{yml,yaml,json,toml}]
indent_size = 2

[Makefile]
indent_style = tab
