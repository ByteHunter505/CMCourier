# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
wheels/
pip-wheel-metadata/
share/python-wheels/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling caches
.ruff_cache/
.mypy_cache/
.pytest_cache/
.tox/
.nox/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# Type-check artifacts
.dmypy.json
dmypy.json

# Pre-commit
.pre-commit/

# Operational artifacts (created at runtime by CMCourier)
logs/
tmp/
/staging/    # ignore runtime ./staging only — anchored to root so scripts/staging/ scaffolding stays tracked (039)
data/migration_tracking.db
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db

# Local secrets — credentials live in env vars per Constitution Principle V/VIII
.env
.env.local
*.local

# pyenv
.python-version

# Generated XLSX test fixtures (deterministic regeneration via tests/conftest.py)
tests/fixtures/sources/*.xlsx

# Generated assembly test fixtures (regenerated by tests/integration/adapters/conftest.py)
tests/fixtures/assembly/**/*.pdf
tests/fixtures/assembly/**/*.PDF
tests/fixtures/assembly/**/*.tif
tests/fixtures/assembly/**/*.tiff
tests/fixtures/assembly/**/*.TIF
tests/fixtures/assembly/**/*.TIFF
tests/fixtures/assembly/**/*.jpg
tests/fixtures/assembly/**/*.jpeg
tests/fixtures/assembly/**/*.JPG
tests/fixtures/assembly/**/*.JPEG
# Numeric-extension page files (.001, .002, ..., .10, .540, etc.)
tests/fixtures/assembly/**/*.[0-9]
tests/fixtures/assembly/**/*.[0-9][0-9]
tests/fixtures/assembly/**/*.[0-9][0-9][0-9]
tests/fixtures/assembly/**/*.[0-9][0-9][0-9][0-9]
